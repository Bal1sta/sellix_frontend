# ---- Sellix frontend (Vite) ----
# Все переменные опциональны. Значения по умолчанию рассчитаны на деплой
# фронта и бэка на ОДНОМ сервере за nginx (запросы идут на тот же origin).

# Базовый путь к API. По умолчанию /api/v1 (тот же домен, без CORS).
# Переопределяйте только если бэк живёт на другом домене.
# VITE_API_BASE=/api/v1

# Базовый origin для медиа-файлов. Пусто = тот же домен (/media/...).
# VITE_MEDIA_BASE=

# Slug магазина-витрины по умолчанию (для общих маршрутов каталога).
# Если пусто — каталог и карточка товара используют локальные демо-данные.
# VITE_DEFAULT_STORE_SLUG=

# OAuth client_id провайдеров (боевой режим). Если пусто — вход эмулируется
# в sandbox-режиме (бэк принимает любой code).
# VITE_YANDEX_CLIENT_ID=
# VITE_VK_CLIENT_ID=

# Адрес бэка для dev-прокси Vite (только npm run dev).
# VITE_DEV_API_TARGET=http://127.0.0.1:8000
